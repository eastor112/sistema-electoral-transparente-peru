APP_NAME=election-system
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=election_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=redis://localhost:6379/0

# TODO: Replace with secure values before staging/production
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

PASSWORD_HASH_ITERATIONS=240000

OTP_CODE_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

EMAIL_PROVIDER=console
EMAIL_FROM=noreply@election-system.local
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

TELEGRAM_PROVIDER=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# OTP HMAC key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
OTP_HMAC_KEY=replace-me-otp

# -----------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage)
# -----------------------------------------------------------------------
# Endpoint: Cloudflare Dashboard → R2 → Overview → Bucket → Settings → S3 API
# Credentials: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=election-assets
# R2_PUBLIC_URL: either a custom domain connected to the bucket, or the R2.dev subdomain
# e.g. https://pub-<HASH>.r2.dev  (only works if public access is enabled)
R2_PUBLIC_URL=https://assets.example.com

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------
# JSON array of allowed origins. Must match the exact origin of the frontend.
# Examples: ["https://app.example.com"] for production
#           ["http://localhost:3000","http://localhost:5173"] for local dev
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
